# Model artifacts & caches (user-supplied / generated — never commit)
*.onnx
*.onnx_data
*.bin
*.npz
mel_filters.npz
# ...but the committed golden feature vectors (small, checked-in references for the fbank test —
# regenerated by scripts/gen_golden_features.py) are an intentional exception.
!tests/golden/*.bin
# Runtime model store only — root-scoped so it does NOT match source directories like
# src/Stt.Core/Models/ (git matches ignore patterns case-insensitively on Windows).
/models/
*_ctx.onnx

# Native libs are restored via NuGet/RID; do not commit binaries
*.dll
*.so
*.dylib
