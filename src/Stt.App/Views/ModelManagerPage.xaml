<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Stt.App.Views.ModelManagerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Stt.App.Views"
    xmlns:conv="using:Stt.App.Converters"
    xmlns:vm="using:Stt.App.ViewModels"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <Grid Padding="20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
            <Button Content="Import folder…" Click="Import_Click" Style="{StaticResource AccentButtonStyle}"
                    AutomationProperties.AutomationId="ImportModelButton"
                    ToolTipService.ToolTip="Sideload a model folder and validate it" />
        </StackPanel>

        <TextBlock Grid.Row="1" Style="{StaticResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                   Text="Sideload a model folder (encoder/decoder/joiner = transducer; single model.onnx = ctc/nar). Models live in %LocalAppData%\Stt\models." />

        <!-- Import / validation result -->
        <muxc:InfoBar Grid.Row="2" IsClosable="True"
                      Severity="{x:Bind local:ModelManagerPage.SeverityFor(ViewModel.IsError), Mode=OneWay}"
                      Message="{x:Bind ViewModel.Status, Mode=OneWay}"
                      IsOpen="{x:Bind local:ModelManagerPage.IsNonEmpty(ViewModel.Status), Mode=OneWay}" />

        <Grid Grid.Row="3">
            <ListView ItemsSource="{x:Bind ViewModel.Models, Mode=OneWay}" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ModelItemViewModel">
                        <Border CornerRadius="{ThemeResource ControlCornerRadius}" Margin="0,4"
                                BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="4">
                                    <TextBlock Text="{x:Bind DisplayName}" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="{x:Bind Family}" Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <muxc:ItemsRepeater ItemsSource="{x:Bind BadgeList}" Margin="0,2,0,0">
                                        <muxc:ItemsRepeater.Layout>
                                            <muxc:StackLayout Orientation="Horizontal" Spacing="6" />
                                        </muxc:ItemsRepeater.Layout>
                                        <muxc:ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="x:String">
                                                <Border CornerRadius="{ThemeResource ControlCornerRadius}" Padding="8,2"
                                                        Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}">
                                                    <TextBlock Text="{x:Bind}" Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                                </Border>
                                            </DataTemplate>
                                        </muxc:ItemsRepeater.ItemTemplate>
                                    </muxc:ItemsRepeater>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Remove" Click="Remove_Click" Tag="{x:Bind Id}"
                                        VerticalAlignment="Top"
                                        ToolTipService.ToolTip="Delete this model from disk" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Empty state -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8"
                        Visibility="{x:Bind ViewModel.HasModels, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                <FontIcon Glyph="&#xE8F1;" FontSize="28" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock Text="No models installed. Use “Import folder…” to add one."
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           Style="{StaticResource BodyTextBlockStyle}" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
