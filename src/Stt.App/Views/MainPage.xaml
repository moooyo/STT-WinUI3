<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Stt.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Stt.App.ViewModels"
    xmlns:conv="using:Stt.App.Converters"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:StringToVisibilityConverter x:Key="StringToVis" />
    </Page.Resources>

    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Controls -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
            <Button Content="Start" Command="{x:Bind ViewModel.StartCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    IsEnabled="{x:Bind ViewModel.IsRecording, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
            <Button Content="Stop" Command="{x:Bind ViewModel.StopCommand}"
                    IsEnabled="{x:Bind ViewModel.IsRecording, Mode=OneWay}" />
            <Button Content="Clear" Command="{x:Bind ViewModel.ClearCommand}" />
            <Border Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    CornerRadius="4" Padding="8,2" VerticalAlignment="Center"
                    Visibility="{x:Bind ViewModel.IsBehind, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="behind" FontSize="12" />
            </Border>
        </StackPanel>

        <!-- Transcript -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="6">
                <ListView ItemsSource="{x:Bind ViewModel.Lines, Mode=OneWay}"
                          SelectionMode="None" IsItemClickEnabled="False">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:TranscriptLine">
                            <TextBlock Text="{x:Bind Text, Mode=OneWay}" TextWrapping="Wrap"
                                       Style="{StaticResource BodyTextBlockStyle}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <!-- Live partial (grey, italic) -->
                <TextBlock Text="{x:Bind ViewModel.PartialText, Mode=OneWay}" TextWrapping="Wrap"
                           FontStyle="Italic" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="12,0"
                           Visibility="{x:Bind ViewModel.PartialText, Mode=OneWay, Converter={StaticResource StringToVis}}" />
            </StackPanel>
        </ScrollViewer>

        <!-- Status -->
        <TextBlock Grid.Row="2" Text="{x:Bind ViewModel.Status, Mode=OneWay}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

        <TextBlock Grid.Row="3" Foreground="{ThemeResource TextFillColorTertiaryBrush}" FontSize="12"
                   Text="Phase 0: speak a sentence → offline SenseVoice transcription (configure models in Settings)." />
    </Grid>
</Page>
