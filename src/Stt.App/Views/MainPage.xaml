<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Stt.App.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Stt.App.Views"
    xmlns:vm="using:Stt.App.ViewModels"
    xmlns:conv="using:Stt.App.Converters"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:StringToVisibilityConverter x:Key="StringToVis" />
    </Page.Resources>

    <Grid Padding="20" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Microphone selection -->
        <ComboBox Grid.Row="0" Header="Microphone" MinWidth="320" MaxWidth="420"
                  HorizontalAlignment="Left" AutomationProperties.AutomationId="MicrophoneComboBox"
                  ItemsSource="{x:Bind ViewModel.Devices, Mode=OneWay}"
                  DisplayMemberPath="Name" SelectedValuePath="Id"
                  SelectedValue="{x:Bind ViewModel.SelectedDeviceId, Mode=TwoWay}"
                  IsEnabled="{x:Bind local:MainPage.Not(ViewModel.IsRecording), Mode=OneWay}" />

        <!-- Commands -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                <Button Content="Start" Command="{x:Bind ViewModel.StartCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        AutomationProperties.AutomationId="StartButton"
                        ToolTipService.ToolTip="Begin listening (start recording)" />
                <Button Content="Stop" Command="{x:Bind ViewModel.StopCommand}"
                        AutomationProperties.AutomationId="StopButton"
                        ToolTipService.ToolTip="Stop listening" />
                <Border Width="1" Margin="4,2" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                <Button Content="Copy" Click="Copy_Click"
                        AutomationProperties.AutomationId="CopyButton"
                        IsEnabled="{x:Bind ViewModel.HasContent, Mode=OneWay}"
                        ToolTipService.ToolTip="Copy the transcript to the clipboard" />
                <Button Content="Export…" Click="Export_Click"
                        AutomationProperties.AutomationId="ExportButton"
                        IsEnabled="{x:Bind ViewModel.HasContent, Mode=OneWay}"
                        ToolTipService.ToolTip="Save the transcript to a text file" />
                <Button Content="Clear" Command="{x:Bind ViewModel.ClearCommand}"
                        AutomationProperties.AutomationId="ClearButton"
                        ToolTipService.ToolTip="Clear the transcript" />
            </StackPanel>

            <Border Grid.Column="1" VerticalAlignment="Center" CornerRadius="{ThemeResource ControlCornerRadius}" Padding="8,3"
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    Visibility="{x:Bind ViewModel.IsBehind, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                    ToolTipService.ToolTip="The engine is dropping audio frames — it is running behind real time.">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE7BA;" FontSize="12"
                              Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                    <TextBlock Text="Behind" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource SystemFillColorCautionBrush}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Actionable errors (mic denied, missing model) -->
        <muxc:InfoBar Grid.Row="2" Severity="Error" Title="Can't start"
                      IsClosable="True"
                      IsOpen="{x:Bind local:MainPage.IsNonEmpty(ViewModel.ErrorMessage), Mode=OneWay}"
                      Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />

        <!-- Transcript card -->
        <Border Grid.Row="3" CornerRadius="{ThemeResource ControlCornerRadius}"
                BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="4">
            <Grid>
                <ListView x:Name="TranscriptList"
                          AutomationProperties.AutomationId="TranscriptList"
                          AutomationProperties.Name="Transcript"
                          ItemsSource="{x:Bind ViewModel.Lines, Mode=OneWay}"
                          SelectionMode="None" IsItemClickEnabled="False">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:TranscriptLine">
                            <TextBlock Text="{x:Bind Text, Mode=OneWay}" TextWrapping="Wrap" IsTextSelectionEnabled="True"
                                       Style="{StaticResource BodyTextBlockStyle}" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="8"
                            Visibility="{x:Bind ViewModel.HasContent, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                    <FontIcon Glyph="&#xE720;" FontSize="28" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock Text="No transcript yet — press Start and speak."
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               Style="{StaticResource BodyTextBlockStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Live partial (grey, italic), pinned below the transcript -->
        <TextBlock Grid.Row="4" Text="{x:Bind ViewModel.PartialText, Mode=OneWay}" TextWrapping="Wrap"
                   FontStyle="Italic" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   AutomationProperties.LiveSetting="Polite"
                   Visibility="{x:Bind ViewModel.PartialText, Mode=OneWay, Converter={StaticResource StringToVis}}" />

        <!-- Status + hint -->
        <StackPanel Grid.Row="5" Spacing="2">
            <TextBlock Text="{x:Bind ViewModel.Status, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       AutomationProperties.LiveSetting="Polite"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       Text="Speak a sentence → offline re-decode produces the final text. Language (zh/en) is auto-detected. Configure models in Settings." />
        </StackPanel>
    </Grid>
</Page>
