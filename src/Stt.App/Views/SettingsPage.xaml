<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Stt.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <ScrollViewer Padding="16">
        <StackPanel Spacing="16" MaxWidth="640" HorizontalAlignment="Left">

            <TextBlock Text="Pipeline" Style="{StaticResource SubtitleTextBlockStyle}" />

            <StackPanel Spacing="4">
                <TextBlock Text="Mode" />
                <ComboBox ItemsSource="{x:Bind ViewModel.Modes}" MinWidth="240"
                          SelectedItem="{x:Bind ViewModel.Mode, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Offline model (second pass)" />
                <ComboBox ItemsSource="{x:Bind ViewModel.OfflineModels, Mode=OneWay}" MinWidth="320"
                          DisplayMemberPath="DisplayName" SelectedValuePath="Id"
                          SelectedValue="{x:Bind ViewModel.SecondPassModelId, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Streaming model (first pass — Phase 1)" />
                <ComboBox ItemsSource="{x:Bind ViewModel.StreamingModels, Mode=OneWay}" MinWidth="320"
                          DisplayMemberPath="DisplayName" SelectedValuePath="Id"
                          SelectedValue="{x:Bind ViewModel.FirstPassModelId, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Execution provider" />
                <ComboBox ItemsSource="{x:Bind ViewModel.Providers}" MinWidth="240"
                          SelectedItem="{x:Bind ViewModel.Ep, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Silero VAD model (.onnx)" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox Text="{x:Bind ViewModel.VadModelPath, Mode=OneWay}" MinWidth="360" IsReadOnly="True" />
                    <Button Content="Browse…" Click="BrowseVad_Click" />
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Endpointing" Style="{StaticResource SubtitleTextBlockStyle}" />

            <StackPanel Spacing="4">
                <TextBlock Text="Min trailing silence (s)" />
                <muxc:NumberBox Value="{x:Bind ViewModel.MinTrailingSilenceSeconds, Mode=TwoWay}"
                                SmallChange="0.1" SpinButtonPlacementMode="Inline" Minimum="0.3" Maximum="3" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Max utterance (s)" />
                <muxc:NumberBox Value="{x:Bind ViewModel.MaxUtteranceSeconds, Mode=TwoWay}"
                                SmallChange="1" SpinButtonPlacementMode="Inline" Minimum="2" Maximum="60" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Save" Command="{x:Bind ViewModel.SaveCommand}" Style="{StaticResource AccentButtonStyle}" />
                <TextBlock Text="{x:Bind ViewModel.Status, Mode=OneWay}" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
