<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Stt.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Stt.App.Views"
    xmlns:controls="using:Stt.App.Controls"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <ScrollViewer>
        <StackPanel Padding="20" Spacing="4" MaxWidth="1000">

            <TextBlock Text="Pipeline" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,2" />

            <controls:SettingCard Header="Mode" Description="Number of recognition passes.">
                <ComboBox MinWidth="240" AutomationProperties.AutomationId="ModeComboBox"
                          ItemsSource="{x:Bind ViewModel.Modes}"
                          SelectedItem="{x:Bind ViewModel.Mode, Mode=TwoWay}" />
            </controls:SettingCard>

            <controls:SettingCard Header="Offline model (second pass)"
                                  Visibility="{x:Bind ViewModel.SecondPassVisibility, Mode=OneWay}"
                                  Description="{x:Bind ViewModel.OfflineModelDescription, Mode=OneWay}">
                <ComboBox MinWidth="280" AutomationProperties.AutomationId="OfflineModelComboBox"
                          ItemsSource="{x:Bind ViewModel.OfflineModels, Mode=OneWay}"
                          DisplayMemberPath="DisplayName" SelectedValuePath="Id"
                          SelectedValue="{x:Bind ViewModel.SecondPassModelId, Mode=TwoWay}" />
            </controls:SettingCard>

            <controls:SettingCard Header="Streaming model (first pass)"
                                  Visibility="{x:Bind ViewModel.FirstPassVisibility, Mode=OneWay}"
                                  Description="{x:Bind ViewModel.StreamingModelDescription, Mode=OneWay}">
                <ComboBox MinWidth="280" AutomationProperties.AutomationId="StreamingModelComboBox"
                          ItemsSource="{x:Bind ViewModel.StreamingModels, Mode=OneWay}"
                          DisplayMemberPath="DisplayName" SelectedValuePath="Id"
                          SelectedValue="{x:Bind ViewModel.FirstPassModelId, Mode=TwoWay}" />
            </controls:SettingCard>

            <controls:SettingCard Header="Execution provider"
                                  Description="{x:Bind ViewModel.DetectedProviders}">
                <ComboBox MinWidth="240" AutomationProperties.AutomationId="ExecutionProviderComboBox"
                          ItemsSource="{x:Bind ViewModel.Providers}"
                          SelectedItem="{x:Bind ViewModel.Ep, Mode=TwoWay}" />
            </controls:SettingCard>

            <TextBlock Text="Drivers" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,12,0,2" />

            <controls:SettingCard Header="Execution-provider drivers"
                                  Description="{x:Bind ViewModel.DriverStatus, Mode=OneWay}">
                <Button Content="Download" Command="{x:Bind ViewModel.DownloadDriversCommand}"
                        AutomationProperties.AutomationId="DownloadDriversButton"
                        ToolTipService.ToolTip="Download + register vendor EP drivers for this hardware (NVIDIA→CUDA/TensorRT, Intel→OpenVINO)" />
            </controls:SettingCard>

            <TextBlock Text="Audio" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,12,0,2" />

            <controls:SettingCard Header="Silero VAD model"
                                  Description="{x:Bind ViewModel.VadModelDescription, Mode=OneWay}">
                <Button Content="Browse…" Click="BrowseVad_Click"
                        AutomationProperties.AutomationId="BrowseVadButton" />
            </controls:SettingCard>

            <TextBlock Text="Endpointing" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,12,0,2" />

            <muxc:Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" IsExpanded="True">
                <muxc:Expander.Header>
                    <StackPanel Spacing="2" Padding="0,8">
                        <TextBlock Text="Endpointing thresholds" Style="{StaticResource BodyTextBlockStyle}" />
                        <TextBlock Text="Silence and duration rules that decide when a segment ends."
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </muxc:Expander.Header>
                <StackPanel Spacing="4" Padding="0,4">
                    <controls:SettingCard Header="Min trailing silence"
                                          Description="Seconds of trailing silence that close a segment.">
                        <muxc:NumberBox MinWidth="160" AutomationProperties.AutomationId="MinTrailingSilenceNumberBox"
                                        Value="{x:Bind ViewModel.MinTrailingSilenceSeconds, Mode=TwoWay}"
                                        SmallChange="0.1" SpinButtonPlacementMode="Inline" Minimum="0.3" Maximum="3" />
                    </controls:SettingCard>
                    <controls:SettingCard Header="Max utterance"
                                          Description="Hard cap on a single segment's length, in seconds.">
                        <muxc:NumberBox MinWidth="160" AutomationProperties.AutomationId="MaxUtteranceNumberBox"
                                        Value="{x:Bind ViewModel.MaxUtteranceSeconds, Mode=TwoWay}"
                                        SmallChange="1" SpinButtonPlacementMode="Inline" Minimum="2" Maximum="60" />
                    </controls:SettingCard>
                </StackPanel>
            </muxc:Expander>

            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,16,0,0">
                <Button Content="Save" Command="{x:Bind ViewModel.SaveCommand}"
                        AutomationProperties.AutomationId="SaveSettingsButton"
                        Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>

            <muxc:InfoBar Severity="Success" IsClosable="True" Margin="0,4,0,0"
                          Title="Saved" Message="{x:Bind ViewModel.Status, Mode=OneWay}"
                          IsOpen="{x:Bind local:SettingsPage.IsNonEmpty(ViewModel.Status), Mode=OneWay}" />
        </StackPanel>
    </ScrollViewer>
</Page>
